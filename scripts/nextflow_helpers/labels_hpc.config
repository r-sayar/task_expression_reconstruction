// ---------------------------------------------------------------------------
// SLURM + Apptainer/Singularity HPC label config for run_benchmark.
//
// Maps the Viash resource labels (lowmem/midmem/highmem/veryhighmem,
// low/mid/high cpu, low/mid/high/veryhigh time, gpu) onto SLURM directives.
//
// >>> CLUSTER-SPECIFIC VALUES YOU MUST SET before launching <<<
//   * params.cpu_partition / params.gpu_partition  (SLURM partition/queue names)
//   * params.slurm_account                         (SLURM account, if required)
//   * the Apptainer cache/tmp dirs and bind mounts below (/lustre paths)
//   * the GPU generic resource string (--gres=gpu:1 vs. type-specific)
//
// Usage:
//   nextflow run . \
//     -main-script target/nextflow/workflows/run_benchmark/main.nf \
//     -profile hpc \
//     -c scripts/nextflow_helpers/labels_hpc.config \
//     -params-file params.yaml
// ---------------------------------------------------------------------------

params {
  // override on the command line or in params.yaml
  // Curta defaults: CPU partition is `main`, GPU is `gpu`, QOS `standard` required.
  cpu_partition = System.getenv('SLURM_CPU_PARTITION') ?: 'main'
  gpu_partition = System.getenv('SLURM_GPU_PARTITION') ?: 'gpu'
  slurm_account = System.getenv('SLURM_ACCOUNT') ?: null
  slurm_qos     = System.getenv('SLURM_QOS') ?: 'standard'
  gpu_gres      = System.getenv('SLURM_GPU_GRES') ?: 'gpu:1'
}

profiles {
  hpc {
    process.executor = 'slurm'

    // Apptainer (a.k.a. Singularity) is the usual HPC container runtime.
    apptainer {
      enabled = true
      autoMounts = true
      // convert the Docker images (openproblems/base_python:1 + pip layers)
      // to .sif once and cache them here on shared storage.
      cacheDir = System.getenv('APPTAINER_CACHEDIR') ?: '/scratch/sayar99/reconeval/apptainer_cache'
    }
    // keep docker/singularity blocks off on HPC
    docker.enabled = false
    singularity.enabled = false
  }
}

def slurmClusterOptions = {
  def opts = []
  if (params.slurm_account) opts << "--account=${params.slurm_account}"
  if (params.slurm_qos) opts << "--qos=${params.slurm_qos}"
  return opts.join(' ')
}

process {
  // conservative retry escalation: OOM/preemption -> bump memory & time
  errorStrategy = { task.exitStatus in [104,134,137,139,140,143,247] && task.attempt <= 3 ? 'retry' : 'finish' }
  maxRetries = 3

  clusterOptions = { slurmClusterOptions() }

  // default (unlabelled) processes
  cpus = 2
  memory = { 8.GB * task.attempt }
  time = { 2.h * task.attempt }
  queue = params.cpu_partition

  // ----- CPU -----
  withLabel: lowcpu  { cpus = 4 }
  withLabel: midcpu  { cpus = 16 }
  withLabel: highcpu { cpus = 32 }

  // ----- MEMORY (escalates on retry) -----
  withLabel: lowmem       { memory = { 20.GB * task.attempt } }
  withLabel: midmem       { memory = { 50.GB * task.attempt } }
  withLabel: highmem      { memory = { 100.GB * task.attempt } }
  withLabel: veryhighmem  { memory = { 200.GB * task.attempt } }

  // ----- WALLTIME -----
  withLabel: lowtime      { time = 1.h }
  withLabel: midtime      { time = 4.h }
  withLabel: hightime     { time = 8.h }
  withLabel: veryhightime { time = 24.h }

  // ----- GPU -----
  // The large models (latent 2048 / width 4096) need a GPU and high memory.
  // Route them to the GPU partition and request a GPU via SLURM --gres.
  withLabel: gpu {
    queue = params.gpu_partition
    clusterOptions = { (slurmClusterOptions() + " --gres=${params.gpu_gres}").trim() }
    // Apptainer needs --nv to expose the GPU inside the container.
    containerOptions = '--nv'
    cpus = 16
    // memory/time come from the other labels the component also carries
    // (e.g. [hightime, highmem, midcpu, gpu]); bump the big models on retry.
    memory = { 100.GB * task.attempt }
    time = { 12.h * task.attempt }
  }

  // publishStates needs a bit of headroom
  withName: '.*publishStatesProc' {
    memory = '16.GB'
    time = '1.h'
  }
}

// tracing
trace {
  enabled = true
  overwrite = true
  file = "${params.publish_dir}/trace.txt"
}
report {
  enabled = true
  overwrite = true
  file = "${params.publish_dir}/report.html"
}
